{
  "name": "panelout-bot",
  "version": "1.0.0",
  "description": "Telegram bot powered by grammY with webhook",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "tunnel:setup": "powershell -ExecutionPolicy Bypass -File tools/cloudflared/setup.ps1",
    "tunnel": "powershell -ExecutionPolicy Bypass -File tools/cloudflared/run.ps1"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@prisma/client": "^6.9.0",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "grammy": "^1.43.0",
    "ioredis": "^5.6.1",
    "node-cron": "^4.2.0",
    "tronweb": "^6.0.4"
  },
  "devDependencies": {
    "prisma": "^6.9.0"
  }
}
