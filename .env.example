# --- Telegram ---
BOT_TOKEN=your_bot_token_here
WEBHOOK_URL=https://your-public-domain.example
WEBHOOK_PATH=/webhook
WEBHOOK_SECRET=change_this_to_a_random_secret
PORT=4444

# --- Database (Docker internal hostnames: postgres / redis) ---
# POSTGRES_PORT / REDIS_PORT are host ports exposed by Docker.
# DATABASE_URL and REDIS_URL always use internal container ports (5432 / 6379).
POSTGRES_USER=panelout
POSTGRES_PASSWORD=change_me
POSTGRES_DB=panelout
POSTGRES_PORT=5433
DATABASE_URL=postgresql://panelout:change_me@postgres:5432/panelout?schema=public

# --- Redis ---
# Host port mapped by Docker; change if 6379 is already in use on the server.
REDIS_PORT=6380
REDIS_URL=redis://redis:6379

# --- App ---
LOG_LEVEL=info
ADMIN_IDS=123456789

# --- Tron / Wallet ---
TRONGRID_API_KEY=your_trongrid_api_key
TRON_NETWORK=mainnet
# TRON_FULL_HOST=https://api.shasta.trongrid.io
SWAPWALLET_API_KEY=apikey-your_swapwallet_key

# --- Cron jobs ---
DEPOSIT_MONITOR_CRON=*/30 * * * * *
WALLET_SWEEP_CRON=0 */10 * * * *
OUTBOUND_USAGE_BILLING_CRON=*/20 * * * * *
PANEL_USAGE_BILLING_CRON=*/20 * * * * *
OUTBOUND_VOLUME_ALERT_CRON=0 */5 * * * *

# --- PasarGuard API ---
PASARGUARD_TIMEOUT_MS=30000
PASARGUARD_MAX_RETRIES=3

# --- Optional tools ---
ADMINER_PORT=8080
